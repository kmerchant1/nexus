# --- Nexus: Core GitIgnore ---

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environments (Crucial: don't push your local setup)
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# AI & Data (Don't push local vector data or logs)
*.log
.vector_store/
.index_cache/
chroma/
pinecone_cache/

# OS and Editor files
.DS_Store
.idea/
.vscode/
*.swp

# Distribution / Packaging
dist/
build/
*.egg-info/
